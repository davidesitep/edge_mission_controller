# =============================================================================
# edge_mission_controller — Configurazione ambiente
# Copia questo file in .env e modifica i valori per il tuo ambiente.
# =============================================================================

# --- ROS Network -----------------------------------------------------------
# URI del roscore in esecuzione sull'host (obbligatorio)
ROS_MASTER_URI=http://192.168.1.123:11311

# IP del container sulla rete ROS (scegli uno dei due metodi):
ROS_IP=192.168.1.123
# ROS_HOSTNAME=192.168.1.123        # alternativa a ROS_IP (usa hostname invece di IP)

# --- Missioni --------------------------------------------------------------
# Cartella sull'host montata come volume nel container
MISSION_DIR=/home/usv/missions

# --- Veicolo ---------------------------------------------------------------
DRONE_ID=1

# --- Servizi gRPC (GCS) ----------------------------------------------------
# Formato: host:porta
# ATTENZIONE: con network_mode:host i nomi Docker service non risolvono.
#             Usare l'IP reale della macchina GCS (es: 192.168.1.100:60001).
NAVDATA_SERVICE_ADDR=192.168.1.151:60001
COMMANDVEL_SERVICE_ADDR=192.168.1.151:60005
GETCONTROL_SERVICE_ADDR=192.168.1.151:60004
SENDMISSION_SERVICE_ADDR=192.168.1.151:60006
